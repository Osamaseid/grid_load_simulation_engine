APP_NAME=VoltStream Grid Feasibility API
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# Grid stress simulation config
GRID_STRESS_MIN_PRICE=0.08
GRID_STRESS_MAX_PRICE=0.45
