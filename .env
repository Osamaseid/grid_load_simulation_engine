DEFAULT_POWER_FACTOR=0.95

# Validation limits
MIN_TRANSFORMER_KW=15
MAX_TRANSFORMER_KW=5000
MAX_EXISTING_CHARGERS=1000
MAX_CHARGER_POWER_KW=350