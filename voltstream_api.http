POST {{baseUrl}}/buildings
Content-Type: application/json

{
  "name": "Downtown Office Tower",
  "address": "123 Main St, New York, NY 10001",
  "building_type": "commercial",
  "transformer_kw": 150,
  "peak_kw": 95,
  "existing_chargers": 4
}

